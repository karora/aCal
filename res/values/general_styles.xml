<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">
	<style name="gen_label">
		<item name="android:textSize">14sp</item>
		<item name="android:paddingLeft">2sp</item>
		<item name="android:textColor">#333366</item>
	</style>
	<color name="themed_text_light">#fff8f020</color>
	<color name="themed_text_dark">#ff001060</color>
	<color name="themed_button_colour">#fff030b0</color>
	<style name="themed_button">
		<item name="android:textSize">16sp</item>
		<item name="android:paddingLeft">3sp</item>
		<item name="android:paddingTop">2sp</item>
		<item name="android:paddingRight">3sp</item>
		<item name="android:paddingBottom">2sp</item>
		<item name="android:background">@drawable/themed_button_fg</item>
		<item name="android:textColor">@color/themed_text_dark</item>
	</style>
	<style name="themed_button_big" parent="themed_button">
		<item name="android:textSize">18sp</item>
		<item name="android:minHeight">32sp</item>
		<item name="android:paddingLeft">5sp</item>
		<item name="android:paddingRight">5sp</item>
	</style>
	<style name="themed_bottom_button">
		<item name="android:textSize">24sp</item>
		<item name="android:textColor">@color/themed_text_dark</item>
		<item name="android:textStyle">bold</item>
		<item name="android:background">@drawable/themed_button_fg</item>
		<item name="android:height">36sp</item>
		<item name="android:paddingLeft">3sp</item>
		<item name="android:paddingTop">2sp</item>
		<item name="android:paddingRight">3sp</item>
		<item name="android:paddingBottom">4sp</item>
	</style>
	<style name="themed_add_button" parent="themed_bottom_button">
		<item name="android:textSize">30sp</item>
		<item name="android:padding">0sp</item>
		<item name="android:clipToPadding">true</item>
	</style>
	<style name="gen_content">
		<item name="android:textSize">18sp</item>
		<item name="android:paddingLeft">10sp</item>
		<item name="android:textColor">#000000</item>
	</style>
	<style name="general_title_bar">
		<item name="android:textColor">#F0F0F0</item>
		<item name="android:textStyle">bold</item>
		<item name="android:textSize">18sp</item>
		<item name="android:padding">0px</item>
		<item name="android:gravity">center_horizontal|top</item>
		<item name="android:background">@drawable/titlebg</item>
		<item name="android:tileMode">repeat</item>
	</style>
	<style name="Theme.aCal.NoActionBar" parent="Theme.aCal.Pink" />

	<!-- Base Material3 theme for aCal. Individual colour variants extend this. -->
	<style name="Theme.aCal.Base" parent="Theme.Material3.Light.NoActionBar">
		<item name="android:windowLightStatusBar">true</item>
		<!-- Preserve the legacy compact toolbar height (Material3 default is 64dp). -->
		<item name="actionBarSize">56dp</item>
		<item name="android:actionBarSize">56dp</item>
		<!-- Material themes' default view inflater auto-substitutes <Button> with
		     MaterialButton, which brings a tonal rounded background that overrides
		     our @drawable/themed_button_fg. Use the plain AppCompat inflater so
		     <Button> stays as AppCompatButton. -->
		<item name="viewInflaterClass">androidx.appcompat.app.AppCompatViewInflater</item>
		<!-- Also strip minHeight/minWidth enforcement for legacy compact buttons. -->
		<item name="buttonStyle">@style/Widget.aCal.LegacyButton</item>
		<item name="android:buttonStyle">@style/Widget.aCal.LegacyButton</item>
	</style>

	<!-- Plain legacy button style: no Material3 surface, no minHeight enforcement. -->
	<style name="Widget.aCal.LegacyButton" parent="android:Widget.Material.Light.Button">
		<item name="android:minHeight">0dp</item>
		<item name="android:minWidth">0dp</item>
	</style>

	<style name="Theme.aCal.Pink" parent="Theme.aCal.Base">
		<item name="colorPrimary">#C2185B</item>
		<item name="colorOnPrimary">#FFFFFF</item>
		<item name="colorPrimaryContainer">#FFD9E2</item>
		<item name="colorOnPrimaryContainer">#3F001D</item>
		<item name="colorSecondary">#75565B</item>
		<item name="colorOnSecondary">#FFFFFF</item>
		<item name="colorTertiary">#7A5733</item>
		<item name="colorOnTertiary">#FFFFFF</item>
	</style>

	<style name="Theme.aCal.Teal" parent="Theme.aCal.Base">
		<item name="colorPrimary">#00796B</item>
		<item name="colorOnPrimary">#FFFFFF</item>
		<item name="colorPrimaryContainer">#74F8E5</item>
		<item name="colorOnPrimaryContainer">#00201C</item>
		<item name="colorSecondary">#4A6360</item>
		<item name="colorOnSecondary">#FFFFFF</item>
		<item name="colorTertiary">#46617A</item>
		<item name="colorOnTertiary">#FFFFFF</item>
	</style>

	<style name="Theme.aCal.Indigo" parent="Theme.aCal.Base">
		<item name="colorPrimary">#3F51B5</item>
		<item name="colorOnPrimary">#FFFFFF</item>
		<item name="colorPrimaryContainer">#DFE0FF</item>
		<item name="colorOnPrimaryContainer">#00105C</item>
		<item name="colorSecondary">#5B5D72</item>
		<item name="colorOnSecondary">#FFFFFF</item>
		<item name="colorTertiary">#77536D</item>
		<item name="colorOnTertiary">#FFFFFF</item>
	</style>

	<style name="Theme.aCal.Green" parent="Theme.aCal.Base">
		<item name="colorPrimary">#2E7D32</item>
		<item name="colorOnPrimary">#FFFFFF</item>
		<item name="colorPrimaryContainer">#B3F1B0</item>
		<item name="colorOnPrimaryContainer">#002204</item>
		<item name="colorSecondary">#53634F</item>
		<item name="colorOnSecondary">#FFFFFF</item>
		<item name="colorTertiary">#386569</item>
		<item name="colorOnTertiary">#FFFFFF</item>
	</style>

	<style name="Theme.aCal.Amber" parent="Theme.aCal.Base">
		<item name="colorPrimary">#8C5000</item>
		<item name="colorOnPrimary">#FFFFFF</item>
		<item name="colorPrimaryContainer">#FFDCBE</item>
		<item name="colorOnPrimaryContainer">#2D1600</item>
		<item name="colorSecondary">#725A42</item>
		<item name="colorOnSecondary">#FFFFFF</item>
		<item name="colorTertiary">#57633B</item>
		<item name="colorOnTertiary">#FFFFFF</item>
	</style>
</resources>