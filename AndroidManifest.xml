            android:launchMode="standard"
            android:theme="@style/Theme.aCal.NoActionBar">
            <intent-filter>
                <action android:name="org.davical.acal.activity.AcalPreferences" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name="org.davical.acal.widget.NumberPicker"
            android:exported="false"
            android:label="Number Picker">
            <intent-filter>
                <action android:name="org.davical.acal.widget.NumberPicker" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name="org.davical.acal.activity.CertificatePinActivity"
            android:exported="false"
            android:label="@string/cert_title_new"
            android:launchMode="singleTop" />

        <service
            android:name="org.davical.acal.service.ContactsSyncAdapterService"
            android:exported="true"
            android:permission="android.permission.WRITE_CONTACTS"
            android:process=":contacts">
            <intent-filter>
                <action android:name="android.content.SyncAdapter" />
            </intent-filter>
            <meta-data
                android:name="android.content.SyncAdapter"
                android:resource="@xml/sync_contacts" />
        </service>

        <provider
            android:name="org.davical.acal.providers.Servers"
            android:authorities="org.davical.acal.servers"
            android:exported="false" />
        <provider
            android:name="org.davical.acal.providers.PathSets"
            android:authorities="org.davical.acal.pathsets"
            android:exported="false" />
        <provider
            android:name="org.davical.acal.providers.Timezones"
            android:authorities="org.davical.acal.timezones"
            android:exported="false" />
        <provider
            android:name="org.davical.acal.providers.DavCollections"
            android:authorities="org.davical.acal.collections"
            android:exported="false" />
        <provider
            android:name="org.davical.acal.providers.CacheDataProvider"
            android:authorities="org.davical.acal.cache"
            android:exported="false" />
        <provider
            android:name="org.davical.acal.providers.AlarmDataProvider"
            android:authorities="org.davical.acal.alarms"
            android:exported="false" />

        <service
            android:name="org.davical.acal.service.aCalService"
            android:exported="false">
            <intent-filter>
                <action android:name="org.davical.acal.service.aCalService" />
            </intent-filter>
        </service>
        <service
            android:name="org.davical.acal.service.AcalAuthenticator"
            android:exported="true"
            android:permission="android.permission.AUTHENTICATE_ACCOUNTS"
            android:process=":auth">
            <intent-filter>
                <action android:name="android.accounts.AccountAuthenticator" />
            </intent-filter>
            <meta-data
                android:name="android.accounts.AccountAuthenticator"
                android:resource="@xml/authenticator" />
        </service>

        <receiver
            android:name="org.davical.acal.receivers.StartUpIntentReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <category android:name="android.intent.category.HOME" />
            </intent-filter>
        </receiver>
        <receiver
            android:name="org.davical.acal.activity.AlarmReceiver"
            android:exported="false" />
        <receiver
            android:name="org.davical.acal.desktop.ShowUpcomingWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/show_upcoming_widget_info" />
        </receiver>
        <receiver
            android:name="org.davical.acal.receivers.TimezoneChangedReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
        </receiver>
        <receiver
            android:name="org.davical.acal.receivers.iMIPReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />

                <data
                    android:pathPattern=".*\\.ics"
                    android:scheme="content" />
                <data
                    android:pathPattern=".*\\.ics"
                    android:scheme="file" />
                <data
                    android:pathPattern=".*\\.ics"
                    android:scheme="http" />
                <data android:scheme="webcal" />
                <data android:mimeType="text/calendar" />
                <!-- the next two lines aren't working atm -->
                <data
                    android:mimeType="application/octet-stream"
                    android:pathPattern=".*\\.ics" />
                <data
                    android:mimeType="text/*"
                    android:pathPattern=".*\\.ics" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
