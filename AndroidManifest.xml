            android:theme="@style/Theme.aCal.NoActionBar">
            <intent-filter>
                <action android:name="org.davical.acal.activity.MonthView" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name="org.davical.acal.activity.YearView"
            android:exported="false"
