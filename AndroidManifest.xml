            </intent-filter>
        </activity>
        <activity
            android:name="org.davical.acal.activity.EventView"
            android:exported="false"
            android:launchMode="standard">
            <intent-filter>
                <action android:name="org.davical.acal.activity.EventView" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name="org.davical.acal.activity.EventEdit"
            android:exported="false"
            android:icon="@drawable/ic_launcher_events"
            android:launchMode="standard">
            <intent-filter>
                <action android:name="org.davical.acal.activity.EventEdit" />
                <category android:name="android.intent.category.DEFAULT" />
